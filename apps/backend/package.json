{
  "name": "@le-tandoor/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "import:menu": "tsx --env-file=.env prisma/import-menu.ts",
    "import:tables": "tsx --env-file=.env prisma/import-tables.ts",
    "import:menus": "tsx --env-file=.env prisma/import-menus.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "@le-tandoor/shared": "0.1.0",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "imapflow": "^1.0.184",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.2",
    "node-thermal-printer": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.7.5",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
